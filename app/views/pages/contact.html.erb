<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Andestellar</title>
  <%content_for :title, "Andestellar"%>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Makozin:wght@300;400;500;700&amp;family=Raleway:wght@300;400;500&amp;display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    html, body {
      height: 100%;
      width: 100%;
    }
    
    .app-wrapper {
      min-height: 100%;
      width: 100%;
      position: relative;
      overflow-x: hidden;
      overflow-y: auto;
    }
    
    .starfield {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
    }
    
    .star {
      position: absolute;
      background: white;
      border-radius: 50%;
      animation: twinkle var(--duration) ease-in-out infinite;
    }
    
    .star-glow {
      box-shadow: 0 0 6px 2px rgba(255, 255, 255, 0.3);
    }
    
    @keyframes twinkle {
      0%, 100% { opacity: var(--min-opacity); transform: scale(1); }
      50% { opacity: 1; transform: scale(1.2); }
    }
    
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    
    @keyframes slideIn {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 20px rgba(212, 175, 55, 0.3); }
      50% { box-shadow: 0 0 40px rgba(212, 175, 55, 0.6); }
    }
    
    .animate-float {
      animation: float 6s ease-in-out infinite;
    }
    
    .animate-slide-in {
      animation: slideIn 1s ease-out forwards;
    }
    
    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-400 { animation-delay: 0.4s; }
    .delay-500 { animation-delay: 0.5s; }
    
    .title-text {
      font-family: 'Makozin', serif;
      color: #d8c8ba;
      letter-spacing: 0.12em;
      font-weight: 300;
      text-transform: uppercase;
    }
    
    .body-text {
      font-family: 'Raleway', sans-serif;
    }
    
    .video-container {
      position: relative;
      overflow: hidden;
      border-radius: 12px;
      border: 1px solid rgba(172, 185, 203, 0.3);
      box-shadow: 0 0 40px rgba(0, 0, 0, 0.5), inset 0 0 60px rgba(0, 0, 0, 0.3);
      background: linear-gradient(135deg, #1a1a2e 0%, #0B0A0A 100%);
    }
    
    .video-container video {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 12px;
    }
    
    .video-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #1a1a2e 0%, #0B0A0A 100%);
      border-radius: 12px;
      padding: 60px 20px;
      text-align: center;
      min-height: 400px;
    }
    
    .cta-button {
      font-family: 'Raleway', sans-serif;
      font-weight: 500;
      letter-spacing: 0.1em;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
      cursor: pointer;
      border: none;
    }
    
    .cta-button::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transition: left 0.5s ease;
    }
    
    .cta-button:hover::before {
      left: 100%;
    }
    
    .whatsapp-btn {
      background: transparent;
      color: #4059ad;
      border: 2px solid #4059ad;
    }
    
    .whatsapp-btn:hover {
      background: #4059ad;
      color: #0B0A0A;
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(64, 89, 173, 0.3);
    }
    
    .social-icon {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(172, 185, 203, 0.3);
      color: #acb9cb;
      transition: all 0.3s ease;
    }
    
    .social-icon:hover {
      background: rgba(172, 185, 203, 0.2);
      border-color: #acb9cb;
      color: #d8c8ba;
      transform: translateY(-3px);
      box-shadow: 0 5px 20px rgba(172, 185, 203, 0.3);
    }
    
    .nebula-glow {
      position: fixed;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      filter: blur(100px);
      opacity: 0.15;
      pointer-events: none;
      z-index: 0;
    }
    
    .nebula-1 {
      top: -200px;
      right: -200px;
      background: radial-gradient(circle, #1a237e 0%, transparent 70%);
    }
    
    .nebula-2 {
      bottom: -200px;
      left: -200px;
      background: radial-gradient(circle, #4a148c 0%, transparent 70%);
    }
    
    .content-wrapper {
      position: relative;
      z-index: 1;
    }
    
    @media (max-width: 768px) {
      .video-placeholder {
        min-height: 300px;
      }
      .title-text {
        font-size: 36px;
      }

      .subtitle-text {
        font-size: 16px;
      }

      #company-name{
        font-size: 22px;
      }

    }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 </head>
